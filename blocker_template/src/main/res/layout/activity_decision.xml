<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#22000000">

    <LinearLayout
        android:id="@+id/card_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginStart="28dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="42dp"
        android:background="@drawable/bg_decision_card"
        android:clickable="true"
        android:elevation="16dp"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/layout_uri_box"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_decision_uri_box"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="52dp"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/text_uri_single"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:lineSpacingExtra="2dp"
                android:maxLines="1"
                android:scrollbars="vertical"
                android:textColor="#4B5563"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_edit"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_button_blue"
                android:minWidth="0dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/decision_edit"
                android:textAllCaps="false"
                android:textColor="#2E6EF7"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/button_reject"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_button_red"
                android:minWidth="0dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/decision_reject"
                android:textAllCaps="false"
                android:textColor="#E24B56"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/button_allow"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_button_green"
                android:minWidth="0dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/decision_allow"
                android:textAllCaps="false"
                android:textColor="#1E9E57"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>