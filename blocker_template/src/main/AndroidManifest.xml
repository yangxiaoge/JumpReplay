                <data android:scheme="blockslot54" />
                <data android:scheme="blockslot55" />
                <data android:scheme="blockslot56" />
                <data android:scheme="blockslot57" />
                <data android:scheme="blockslot58" />
                <data android:scheme="blockslot59" />
                <data android:scheme="blockslot60" />
                <data android:scheme="blockslot61" />
                <data android:scheme="blockslot62" />
                <data android:scheme="dewulink" />
            </intent-filter>
        </activity>

        <!-- 未命中规则时的决策弹窗 -->
        <activity
            android:name="com.fourtwo.blockertemplate.DecisionActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:finishOnTaskLaunch="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- 管理页：桌面可见 -->
        <activity
            android:name="com.fourtwo.blockertemplate.ManageActivity"
            android:exported="true"
            android:label="意图拦截器">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>
</manifest>